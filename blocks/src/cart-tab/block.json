{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mercantile/cart-tab",
	"version": "1.0.0",
	"title": "Cart Tab",
	"category": "theme",
	"description": "Live cart link for the ticker bar. The item count is derived from WooCommerce's Interactivity API cart store and updates whenever a product is added or removed anywhere on the page.",
	"icon": "cart",
	"textdomain": "mercantile-hook-loop",
	"attributes": {
		"cartUrl": {
			"type": "string",
			"default": ""
		},
		"label": {
			"type": "string",
			"default": "cart"
		},
		"textColor": {
			"type": "string",
			"default": "text-on-ink"
		},
		"style": {
			"type": "object",
			"default": {
				"spacing": { "padding": { "top": "0", "right": "12px", "bottom": "0", "left": "12px" } },
				"border": { "left": { "color": "var:preset|color|divider-on-ink", "width": "1px", "style": "solid" } }
			}
		}
	},
	"supports": {
		"html": false,
		"interactivity": true,
		"className": true,
		"customClassName": true,
		"color": {
			"background": true,
			"text": true,
			"link": false
		},
		"spacing": {
			"padding": true,
			"__experimentalDefaultControls": { "padding": true }
		},
		"__experimentalBorder": {
			"color": true,
			"style": true,
			"width": true,
			"__experimentalDefaultControls": { "color": true, "width": true }
		}
	},
	"editorScript": "file:./index.js",
	"viewScriptModule": "file:./view.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
