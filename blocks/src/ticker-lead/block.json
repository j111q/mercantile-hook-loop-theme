{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mercantile/ticker-lead",
	"version": "1.0.0",
	"title": "Ticker Lead",
	"category": "theme",
	"description": "Site mark + LIVE indicator that anchors the ticker bar. The pulsing status dot is rendered as a CSS ::before on the LIVE label.",
	"icon": "podio",
	"textdomain": "mercantile-hook-loop",
	"attributes": {
		"href": {
			"type": "string",
			"default": ""
		},
		"ariaLabel": {
			"type": "string",
			"default": "Mercantile home"
		},
		"liveText": {
			"type": "string",
			"default": "LIVE"
		},
		"size": {
			"type": "number",
			"default": 14
		},
		"backgroundColor": {
			"type": "string",
			"default": "ink"
		},
		"textColor": {
			"type": "string",
			"default": "text-on-ink"
		},
		"style": {
			"type": "object",
			"default": {
				"spacing": { "padding": { "top": "0", "right": "12px", "bottom": "0", "left": "12px" } },
				"typography": { "fontWeight": "600" },
				"border": { "right": { "color": "var:preset|color|divider-on-ink", "width": "1px", "style": "solid" } }
			}
		}
	},
	"supports": {
		"html": false,
		"className": true,
		"customClassName": true,
		"color": {
			"background": true,
			"text": true,
			"link": false
		},
		"spacing": {
			"padding": true,
			"__experimentalDefaultControls": { "padding": true }
		},
		"typography": {
			"__experimentalFontWeight": true,
			"__experimentalDefaultControls": { "fontWeight": true }
		},
		"__experimentalBorder": {
			"color": true,
			"style": true,
			"width": true,
			"__experimentalDefaultControls": { "color": true, "width": true }
		}
	},
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
